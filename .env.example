# Google OAuth2 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Callback URL — use http://localhost:3000/auth/google/callback for local dev
# Use https://your-app.up.railway.app/auth/google/callback for production
REDIRECT_URI=http://localhost:3000/auth/google/callback

# Google Sheets spreadsheet ID (from the URL of your Sheet)
SPREADSHEET_ID=your-spreadsheet-id

# Random strong string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-random-secret

# Set to "production" on Railway
NODE_ENV=development
